{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "main.js",
    "preload.js",
    "client-portal-standalone.js",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "build"
  ]
}
